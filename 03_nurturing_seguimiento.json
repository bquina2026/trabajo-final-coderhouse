      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO failed_queue (workflow_id, error_message, payload, created_at)\nVALUES ('WF3', '{{ $json.error.message }}', '{{ JSON.stringify($json).substring(0, 1000) }}', NOW());",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "postgres-medflow-prod",
          "name": "Postgres MedFlow Prod"
        }
      }
    }
  ],
  "connections": {
